# RiftCampus Backend — Variables de Entorno
# Copiá este archivo como .env y completá los valores
# NUNCA subas el .env real al repositorio
# ──────────────────────────────────────────────────────

# Base de datos
DB_HOST=localhost
DB_USER=root
DB_PASS=tu_clave_segura
DB_NAME=riftcampus

# JWT — usá una cadena larga y aleatoria
JWT_SECRET=firma_criptografica_inviolable_cambiar_esto

# Servidor
PORT=3000
